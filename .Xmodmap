!Super and Alt swap
! I know i know a little bit bloated but at least works
remove Mod1 = Alt_L
remove Mod4 = Super_L
add Mod1 = Super_L
add Mod4 = Alt_L
keycode 133 = Alt_L
keycode 64 = Super_L
!keysym Super_L = Alt_L
!keysym Alt_L = Super_L

! Swap caps lock and escape
remove Lock = Caps_Lock
keysym Escape = Caps_Lock
keysym Caps_Lock = Escape
add Lock = Caps_Lock


